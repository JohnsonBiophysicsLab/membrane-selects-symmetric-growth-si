Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "function", " ", "f"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x_", ",", "a_", ",", "b_", ",", "c_"}], "]"}], ":=", 
    RowBox[{"x", "*", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"c", "+", 
         RowBox[{"b", "/", "x"}], "+", 
         RowBox[{
          RowBox[{"b", "^", "3"}], "/", "x"}]}], ")"}], "^", "2"}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"b", "^", "2"}]}], ")"}], "^", "3"}]}]}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Replace", " ", "variables"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"fReplaced", "=", 
    RowBox[{"f", "[", 
     RowBox[{"\[Rho]", ",", 
      RowBox[{"h", "[", "\[Rho]", "]"}], ",", 
      RowBox[{
       RowBox[{"h", "'"}], "[", "\[Rho]", "]"}], ",", 
      RowBox[{
       RowBox[{"h", "''"}], "[", "\[Rho]", "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "partial", " ", "derivatives"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"dfdb", "=", 
    RowBox[{"D", "[", 
     RowBox[{"fReplaced", ",", 
      RowBox[{
       RowBox[{"h", "'"}], "[", "\[Rho]", "]"}]}], "]"}]}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Partial", " ", "derivative", " ", 
      RowBox[{"w", ".", "r", ".", "t"}], " ", "b"}], "=", 
     RowBox[{
      RowBox[{"h", "'"}], "[", "rho", "]"}]}], "*)"}], "\n", 
   RowBox[{"dfdc", "=", 
    RowBox[{"D", "[", 
     RowBox[{"fReplaced", ",", 
      RowBox[{
       RowBox[{"h", "''"}], "[", "\[Rho]", "]"}]}], "]"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Partial", " ", "derivative", " ", 
      RowBox[{"w", ".", "r", ".", "t"}], " ", "c"}], "=", 
     RowBox[{
      RowBox[{"h", "''"}], "[", "rho", "]"}]}], "*)"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "the", " ", "required", " ", "derivatives"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ddfdbdrho", "=", 
    RowBox[{"D", "[", 
     RowBox[{"dfdb", ",", "\[Rho]"}], "]"}]}], "    ", 
   RowBox[{"(*", 
    RowBox[{"First", " ", "derivative", " ", "of", " ", "dfdb", " ", 
     RowBox[{"w", ".", "r", ".", "t"}], " ", "rho"}], "*)"}], "\n", 
   RowBox[{"d2dfdcdrho2", "=", 
    RowBox[{"D", "[", 
     RowBox[{"dfdc", ",", 
      RowBox[{"{", 
       RowBox[{"\[Rho]", ",", "2"}], "}"}]}], "]"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{"Second", " ", "derivative", " ", "of", " ", "dfdc", " ", 
     RowBox[{"w", ".", "r", ".", "t"}], " ", "rho"}], "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "the", " ", "equation"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqn", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"ddfdbdrho", "-", "d2dfdcdrho2"}], "==", "0"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Solve", " ", "for", " ", 
     RowBox[{"h", "^", 
      RowBox[{
       RowBox[{"(", "4", ")"}], "[", "rho", "]"}]}], " ", "explicitly"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solvedEqn", "=", 
     RowBox[{"Solve", "[", 
      RowBox[{"eqn", ",", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"h", "[", "\[Rho]", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Rho]", ",", "4"}], "}"}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
